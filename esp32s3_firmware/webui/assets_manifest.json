{
  "note": "Optional media assets from 738NGX/RinaChanBoard Unity Resources. Upload only selected files if ESP32-S3 flash capacity is sufficient; LED timeline playback works without these media files.",
  "source_repo": "https://github.com/738NGX/RinaChanBoard",
  "source_root": "RinaChanBoardOperationCenter/Assets/Resources",
