  },
  "music": [
    "webui/assets/music/music_lumf.ogg",
    "webui/assets/music/music_solo0.ogg",
    "webui/assets/music/music_solo1.ogg",
    "webui/assets/music/music_solo2.ogg",
    "webui/assets/music/music_solo3.ogg",
    "webui/assets/music/music_solo4.ogg",
    "webui/assets/music/music_solo5.ogg",
    "webui/assets/music/music_tkmk.ogg"
  ],
  "video": [
    "webui/assets/video/video_C&R01.mp4",
    "webui/assets/video/video_C&R02.mp4",
    "webui/assets/video/video_C&R11.mp4",
    "webui/assets/video/video_C&R12.mp4",
    "webui/assets/video/video_TVS101.mp4",
    "webui/assets/video/video_TVS102.mp4",
    "webui/assets/video/video_TVS103.mp4"
  ],
  "voice_pattern": "webui/assets/voice/voice_<id>.ogg"
